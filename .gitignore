```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
*.out

# Dependencies
.venv/
venv/
node_modules/
target/
.gradle/
.mypy_cache/
.pytest_cache/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# System files
.DS_Store
Thumbs.db
```